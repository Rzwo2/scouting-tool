<nav id="nav-top">
    <a href="{{ path('statistic_overview') }}">
        <image src="{{ asset('media/images/logo.png')}}" width="250px">
    </a>
    <h1>{{ headline }}</h1>
    <div id="profile">
        <a href="{{ path('app_profile') }}"
           class="nav-icon{% if app.request.pathinfo starts with '/profile' %} nav-icon--active{% endif %}"
           title="Profil">
            <svg width="24" height="24" aria-hidden="true"><use href="#icon-person"/></svg>
        </a>

        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin') }}"
           class="nav-icon{% if app.request.pathinfo starts with '/admin' %} nav-icon--active{% endif %}"
           title="Administration">
            <svg width="24" height="24" aria-hidden="true"><use href="#icon-gear"/></svg>
        </a>
        {% endif %}

        <a href="{{ path('app_logout') }}"
           class="nav-icon"
           title="Abmelden">
            <svg width="24" height="24" aria-hidden="true"><use href="#icon-logout"/></svg>
        </a>
    </div>
</nav>
